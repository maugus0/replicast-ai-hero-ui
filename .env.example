# Replicast AI Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# PUBLIC VARIABLES (exposed to the browser via NEXT_PUBLIC_ prefix)
# =============================================================================

# Base path for GitHub Pages deployment (set by CI, leave empty for local dev)
NEXT_PUBLIC_BASE_PATH=

# Formspree form ID for demo request form
# Get yours at https://formspree.io
NEXT_PUBLIC_FORMSPREE_ID=

# Site URL for SEO/OG tags
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App version (set by CI from git tag)
NEXT_PUBLIC_APP_VERSION=
